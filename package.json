{
  "name": "drift-watch",
  "version": "0.1.0",
  "description": "Drift and repetitive error analyzer for AI agentic coding sessions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "drift-watch": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "check": "tsc --noEmit && eslint src/ && prettier --check 'src/**/*.ts'",
    "prepublishOnly": "pnpm run build",
    "prepare": "husky"
  },
  "keywords": [
    "ai",
    "drift-detection",
    "agentic",
    "code-quality"
  ],
  "author": "Nathan Delacretaz",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nathandela/drift-watch.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": []
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.3.5",
    "compound-agent": "^1.6.4",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "mysql2": "^3.19.0",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  }
}
