{
  "name": "drift-watch",
  "version": "0.1.0",
  "description": "Drift and repetitive error analyzer for AI agentic coding sessions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "check": "tsc --noEmit && eslint src/ && prettier --check 'src/**/*.ts'",
    "prepare": "husky"
  },
  "keywords": [
    "ai",
    "drift-detection",
    "agentic",
    "code-quality"
  ],
  "author": "Nathan Delacretaz",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "node-llama-cpp"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "compound-agent": "^1.6.4",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
